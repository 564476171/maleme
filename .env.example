# Copy this file to .env, then set ADMIN_PASSWORD before starting.
# Database settings are optional; APP_SECRET is generated inside Docker.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
APP_PORT=6088

# Optional database overrides. The database is not exposed outside Docker.
# POSTGRES_USER=maleme
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=maleme
