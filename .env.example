# You normally do not need to copy this file.
# Run ./deploy.sh and it will generate .env automatically.
# You will be asked to set the initial admin password.

POSTGRES_USER=maleme
POSTGRES_PASSWORD=auto-generated-by-deploy-sh
POSTGRES_DB=maleme
DATABASE_URL=postgresql://maleme:auto-generated-by-deploy-sh@postgres:5432/maleme?schema=public
APP_SECRET=auto-generated-by-deploy-sh
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-your-own-admin-password
APP_PORT=6088
